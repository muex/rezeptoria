{#
  Reusable advertisement slot — Apple-style, unobtrusive.

  The slot renders *only* when real ad markup is supplied via the `code`
  param (e.g. a Google AdSense <ins class="adsbygoogle"> snippet). Without
  it nothing is output, so empty placeholders never take up space.

  Params:
    code   : the ad network markup to embed. When empty the slot is hidden.
    format : 'leaderboard' | 'rectangle' | 'skyscraper' | 'infeed'  (default 'rectangle')
    label  : override the small disclosure label  (default 'Anzeige')
#}
{% set code = code|default('')|trim %}

{% if code is not empty %}
    {% set format = format|default('rectangle') %}
    {% set label  = label|default('Anzeige') %}

    {% set sizes = {
        'leaderboard': 'w-full min-h-[90px] md:min-h-[120px]',
        'rectangle':   'w-full max-w-[336px] min-h-[280px] mx-auto',
        'skyscraper':  'w-full min-h-[600px]',
        'infeed':      'w-full min-h-[320px] h-full'
    } %}

    <aside class="ad-slot group {{ sizes[format] ?? sizes['rectangle'] }} relative flex flex-col items-center justify-center
                  rounded-3xl border border-black/5 bg-white/60 backdrop-blur-xl
                  text-center overflow-hidden"
           aria-label="{{ label }}">
        <span class="absolute top-3 left-4 text-[10px] font-medium uppercase tracking-[0.12em] text-gray-400">
            {{ label }}
        </span>

        {{ code|raw }}
    </aside>
{% endif %}
