{{ form_start(form) }}
<div class="space-y-6">

    {{ form_row(form.title) }}
    {{ form_row(form.text) }}

    <div class="flex items-center gap-3">
        <label class="font-medium text-gray-700 text-sm">Grundmenge für</label>
        {{ form_widget(form.baseServings, {attr: {class: 'w-20 border border-gray-300 rounded px-2 py-1 text-sm', min: 1}}) }}
        <span class="text-sm text-gray-600">Portionen</span>
    </div>

    {# ── Sections collection ──────────────────────────────────────── #}
    <div id="sections-wrapper"
         data-prototype="{{ form_widget(form.sections.vars.prototype)|e('html_attr') }}"
         data-index="{{ form.sections|length }}">

        <h3 class="font-semibold text-gray-800 mb-3">Abschnitte</h3>

        <div id="sections-list" class="space-y-4">
            {% for section in form.sections %}
                <div class="section-item border border-gray-200 rounded-lg p-4 bg-gray-50">

                    <div class="flex justify-between items-center mb-3">
                        <span class="font-medium text-gray-700">Abschnitt</span>
                        <button type="button" class="remove-section-btn text-red-500 text-sm hover:text-red-700">× Entfernen</button>
                    </div>

                    {{ form_row(section.title, {label: 'Titel des Abschnitts'}) }}

                    {# ── Ingredients ───────────────────────────────── #}
                    <div class="ingredients-wrapper mt-4"
                         data-prototype="{{ form_widget(section.ingredients.vars.prototype)|e('html_attr') }}"
                         data-index="{{ section.ingredients|length }}">

                        <p class="text-sm font-medium text-gray-700 mb-2">Zutaten</p>
                        <div class="ingredients-list space-y-2">
                            {% for ingredient in section.ingredients %}
                                <div class="ingredient-item flex items-center gap-2">
                                    {{ form_widget(ingredient.amount) }}
                                    {{ form_widget(ingredient.unit) }}
                                    {{ form_widget(ingredient.name) }}
                                    <button type="button" class="remove-ingredient-btn text-red-400 hover:text-red-600 px-1">×</button>
                                </div>
                            {% endfor %}
                        </div>

                        <button type="button" class="add-ingredient-btn mt-2 text-sm text-pinegreen hover:underline">
                            + Zutat hinzufügen
                        </button>
                    </div>

                    {{ form_row(section.preparation, {label: 'Zubereitung'}) }}
                </div>
            {% endfor %}
        </div>

        <button type="button" id="add-section-btn"
                class="mt-4 border border-pinegreen text-pinegreen px-4 py-2 rounded-lg text-sm hover:bg-pinegreen hover:text-white transition-colors">
            + Abschnitt hinzufügen
        </button>
    </div>

    {{ form_row(form.teaserImage) }}
    {{ form_row(form.categories) }}
</div>

<button class="w-full bg-pinegreen hover:bg-pinegreen-40 text-white font-medium py-2.5 rounded-lg transition-colors mt-6">
    {{ button_label|default('Speichern') }}
</button>
{{ form_end(form) }}

<script>
document.addEventListener('DOMContentLoaded', function () {
    var sectionsWrapper = document.getElementById('sections-wrapper');
    var sectionsList    = document.getElementById('sections-list');

    function setupIngredientButtons(sectionEl) {
        var ingredientsWrapper = sectionEl.querySelector('.ingredients-wrapper');
        if (!ingredientsWrapper) return;

        var addBtn = sectionEl.querySelector('.add-ingredient-btn');
        if (addBtn) {
            addBtn.addEventListener('click', function () {
                addIngredient(ingredientsWrapper);
            });
        }

        sectionEl.querySelectorAll('.remove-ingredient-btn').forEach(function (btn) {
            btn.addEventListener('click', function () {
                btn.closest('.ingredient-item').remove();
            });
        });
    }

    function addIngredient(ingredientsWrapper) {
        var prototype = ingredientsWrapper.dataset.prototype;
        var index     = parseInt(ingredientsWrapper.dataset.index || '0');
        var html      = prototype.replace(/__ingredient__/g, index);
        ingredientsWrapper.dataset.index = index + 1;

        var div = document.createElement('div');
        div.className = 'ingredient-item flex items-center gap-2';
        div.innerHTML = html;

        var removeBtn = document.createElement('button');
        removeBtn.type = 'button';
        removeBtn.className = 'remove-ingredient-btn text-red-400 hover:text-red-600 px-1';
        removeBtn.textContent = '×';
        removeBtn.addEventListener('click', function () { div.remove(); });
        div.appendChild(removeBtn);

        ingredientsWrapper.querySelector('.ingredients-list').appendChild(div);
    }

    function addSection() {
        var prototype = sectionsWrapper.dataset.prototype;
        var index     = parseInt(sectionsWrapper.dataset.index || '0');
        var html      = prototype.replace(/__section__/g, index);
        sectionsWrapper.dataset.index = index + 1;

        var div = document.createElement('div');
        div.className = 'section-item border border-gray-200 rounded-lg p-4 bg-gray-50';
        div.innerHTML = html;

        // prepend header with remove button
        var header = document.createElement('div');
        header.className = 'flex justify-between items-center mb-3';
        var label = document.createElement('span');
        label.className = 'font-medium text-gray-700';
        label.textContent = 'Abschnitt';
        var removeBtn = document.createElement('button');
        removeBtn.type = 'button';
        removeBtn.className = 'remove-section-btn text-red-500 text-sm hover:text-red-700';
        removeBtn.textContent = '× Entfernen';
        removeBtn.addEventListener('click', function () { div.remove(); });
        header.appendChild(label);
        header.appendChild(removeBtn);
        div.prepend(header);

        setupIngredientButtons(div);
        sectionsList.appendChild(div);
    }

    document.getElementById('add-section-btn').addEventListener('click', addSection);

    // wire up existing sections
    document.querySelectorAll('.section-item').forEach(function (sectionEl) {
        var removeBtn = sectionEl.querySelector('.remove-section-btn');
        if (removeBtn) {
            removeBtn.addEventListener('click', function () { sectionEl.remove(); });
        }
        setupIngredientButtons(sectionEl);
    });
});
</script>
